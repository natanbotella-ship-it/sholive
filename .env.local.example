# Site — nécessaire pour les redirections email (reset password, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Dashboard > Developers > API keys / Webhooks (nécessaire à partir du Bloc 07)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Alertes admin (src/lib/notify-admin.ts) — pre-mortem 2026-07-06. Optionnel mais
# fortement recommandé avant le lancement : sans ça, un Transfer échoué ou un
# challenge remboursé ne sont visibles que dans les logs Vercel / la DB.
# Resend (https://resend.com) : clé API + adresse email de Natan.
RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=
ADMIN_NOTIFICATION_FROM=

# Cron (src/app/api/cron/*) — pre-mortem 2026-07-06. Secret partagé vérifié dans
# le header Authorization par les routes cron, pour qu'elles ne soient
# déclenchables que par Vercel Cron (ou toi, manuellement, avec ce secret) et pas
# par n'importe qui trouvant l'URL. Vercel envoie automatiquement ce header aux
# crons définis dans vercel.json — rien à faire depuis le dashboard.
CRON_SECRET=
